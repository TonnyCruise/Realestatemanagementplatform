generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  LANDLORD
  TENANT
  SEEKER
  ADMIN
}

enum Country {
  KE
  TZ
  UG
}

enum Currency {
  KES
  TZS
  UGX
}

enum PropertyType {
  APARTMENT
  HOUSE
  BEDSITTER
  STUDIO
  COMMERCIAL
  LAND
}

enum PropertyStatus {
  AVAILABLE
  OCCUPIED
  UNLISTED
  PENDING_VERIFICATION
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum TenancyStatus {
  PENDING
  ACTIVE
  ENDING
  ENDED
}

enum DepositStatus {
  PENDING
  PAID
  REFUNDED
  WITHHELD
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  CANCELLED
}

enum PaymentMethod {
  MPESA
  AIRTEL_MONEY
  MTN_MOMO
  CARD
  BANK_TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  STRUCTURAL
  APPLIANCE
  SECURITY
  CLEANING
  OTHER
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  RENT_DUE
  RENT_PAID
  MAINTENANCE_UPDATE
  LEASE_EXPIRY
  SUBSCRIPTION_RENEWAL
  GENERAL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  phone         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          Role
  country       Country
  profilePhoto  String?
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  ownedProperties     Property[]           @relation("LandlordProperties")
  tenancies           Tenancy[]            @relation("TenantTenancies")
  landlordTenancies   Tenancy[]            @relation("LandlordTenancies")
  invoicesAsTenant    Invoice[]            @relation("TenantInvoices")
  invoicesAsLandlord  Invoice[]            @relation("LandlordInvoices")
  payments            Payment[]
  reviews             Review[]
  subscription        Subscription?
  maintenanceRequests MaintenanceRequest[]
  notifications       Notification[]
  otpTokens           OtpToken[]

  @@map("users")
}

model OtpToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_tokens")
}

model Property {
  id           String         @id @default(uuid())
  landlordId   String
  title        String
  description  String
  type         PropertyType
  address      String
  city         String
  country      Country
  lat          Decimal        @db.Decimal(10, 7)
  lng          Decimal        @db.Decimal(10, 7)
  pricePerMonth Decimal       @db.Decimal(12, 2)
  currency     Currency
  status       PropertyStatus @default(AVAILABLE)
  amenities    Json           @default("[]")
  photos       Json           @default("[]")
  avgRating    Decimal        @default(0) @db.Decimal(3, 2)
  totalReviews Int            @default(0)
  isFeatured   Boolean        @default(false)
  isVerified   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  landlord  User     @relation("LandlordProperties", fields: [landlordId], references: [id])
  units     Unit[]
  reviews   Review[]

  @@map("properties")
}

model Unit {
  id           String     @id @default(uuid())
  propertyId   String
  unitNumber   String
  floor        Int?
  bedrooms     Int        @default(1)
  bathrooms    Int        @default(1)
  sizeSqft     Decimal?   @db.Decimal(8, 2)
  monthlyRent  Decimal    @db.Decimal(12, 2)
  status       UnitStatus @default(VACANT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancies           Tenancy[]
  maintenanceRequests MaintenanceRequest[]

  @@unique([propertyId, unitNumber])
  @@map("units")
}

model Tenancy {
  id                String        @id @default(uuid())
  tenantId          String
  unitId            String
  landlordId        String
  startDate         DateTime
  endDate           DateTime?
  rentAmount        Decimal       @db.Decimal(12, 2)
  depositAmount     Decimal       @db.Decimal(12, 2)
  depositStatus     DepositStatus @default(PENDING)
  leaseDocumentUrl  String?
  status            TenancyStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant   User      @relation("TenantTenancies", fields: [tenantId], references: [id])
  landlord User      @relation("LandlordTenancies", fields: [landlordId], references: [id])
  unit     Unit      @relation(fields: [unitId], references: [id])
  invoices Invoice[]

  @@map("tenancies")
}

model Invoice {
  id         String        @id @default(uuid())
  tenancyId  String
  tenantId   String
  landlordId String
  amount     Decimal       @db.Decimal(12, 2)
  dueDate    DateTime
  period     String        // e.g. "2026-05"
  breakdown  Json          @default("{}")
  status     InvoiceStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenancy  Tenancy   @relation(fields: [tenancyId], references: [id])
  tenant   User      @relation("TenantInvoices", fields: [tenantId], references: [id])
  landlord User      @relation("LandlordInvoices", fields: [landlordId], references: [id])
  payments Payment[]

  @@unique([tenancyId, period])
  @@map("invoices")
}

model Payment {
  id           String        @id @default(uuid())
  invoiceId    String
  payerId      String
  amount       Decimal       @db.Decimal(12, 2)
  currency     Currency
  method       PaymentMethod
  providerRef  String?       @unique
  providerData Json?
  status       PaymentStatus @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  payer   User    @relation(fields: [payerId], references: [id])

  @@map("payments")
}

model Review {
  id                String   @id @default(uuid())
  propertyId        String
  reviewerId        String
  rating            Int
  title             String?
  body              String
  categories        Json     @default("{}")
  isVerifiedTenant  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reviewer User     @relation(fields: [reviewerId], references: [id])

  @@unique([propertyId, reviewerId])
  @@map("reviews")
}

model Subscription {
  id                  String             @id @default(uuid())
  landlordId          String             @unique
  plan                SubscriptionPlan   @default(STARTER)
  billingCycle        BillingCycle       @default(MONTHLY)
  country             Country
  price               Decimal            @db.Decimal(10, 2)
  currency            Currency
  status              SubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  flutterwaveSubId    String?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  landlord User @relation(fields: [landlordId], references: [id])

  @@map("subscriptions")
}

model MaintenanceRequest {
  id          String              @id @default(uuid())
  unitId      String
  tenantId    String
  title       String
  description String
  category    MaintenanceCategory
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)
  photos      Json                @default("[]")
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  unit   Unit @relation(fields: [unitId], references: [id])
  tenant User @relation(fields: [tenantId], references: [id])

  @@map("maintenance_requests")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
